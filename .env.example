# Ortam degiskenleri sablonu. Gercek degerleri .env (yerel) ve Railway Variables'a gir.

# Railway PostgreSQL eklentisi otomatik saglar.
DATABASE_URL=
# Public Postgres dizesi kullaniyorsan true yap.
DATABASE_SSL=false

# Oturum imzalama anahtari (uzun, rastgele).
JWT_SECRET=

# Resend (https://resend.com -> API Keys)
RESEND_API_KEY=
MAIL_FROM=MoS Rhythm <onboarding@resend.dev>

# Bu e-posta ile dogrulanan kullanici otomatik admin olur.
ADMIN_EMAIL=

# Canli URL (orn. https://visual-production-b3fc.up.railway.app)
APP_URL=http://localhost:4174
